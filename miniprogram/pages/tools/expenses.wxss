/* pages/tools/expenses.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 预算卡片 */
.budget-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.budget-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.budget-title {
  font-size: 32rpx;
  font-weight: bold;
}

.btn-toggle {
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.2);
  color: white;
  border-radius: 16rpx;
  font-size: 24rpx;
  border: none;
}

.budget-stats {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  opacity: 0.9;
  margin-bottom: 8rpx;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
}

.stat-value.budget {
  color: white;
}

.stat-value.spent {
  color: #FFD700;
}

.stat-value.remaining {
  color: #90EE90;
}

.stat-value.remaining.over {
  color: #FF6B6B;
}

.budget-progress {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.progress-fill {
  height: 100%;
  background: white;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-text {
  display: block;
  font-size: 24rpx;
  opacity: 0.9;
}

/* 添加表单 */
.add-form {
  padding: 24rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
}

.input-row {
  margin-bottom: 20rpx;
}

.input-label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.amount-input {
  width: 100%;
  padding: 16rpx 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.category-scroll {
  white-space: nowrap;
}

.category-chip {
  display: inline-block;
  padding: 12rpx 20rpx;
  margin-right: 12rpx;
  background: #f5f5f5;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #666666;
  border: 2rpx solid transparent;
}

.category-chip.active {
  background: #fff3e0;
  color: #FF9800;
  border-color: #FF9800;
}

.date-picker {
  padding: 16rpx 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333333;
}

.desc-input {
  width: 100%;
  padding: 16rpx 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.btn-submit {
  width: 100%;
  padding: 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  margin-top: 24rpx;
}

/* 统计图表 */
.stats-section {
  padding: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.stat-bar {
  margin-bottom: 24rpx;
}

.stat-bar:last-child {
  margin-bottom: 0;
}

.stat-bar-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.stat-bar-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.stat-bar-name {
  font-size: 28rpx;
  color: #333333;
  flex: 1;
}

.stat-bar-amount {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-right: 12rpx;
}

.stat-bar-percent {
  font-size: 24rpx;
  color: #999999;
}

.stat-bar-progress {
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.stat-bar-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

/* 费用列表 */
.expenses-list {
  margin-top: 24rpx;
}

.expense-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
}

.expense-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.expense-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.expense-icon text {
  font-size: 32rpx;
}

.expense-info {
  flex: 1;
}

.expense-category {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 4rpx;
}

.expense-desc {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 4rpx;
}

.expense-date {
  display: block;
  font-size: 22rpx;
  color: #cccccc;
}

.expense-right {
  display: flex;
  align-items: center;
}

.expense-amount {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff4d4f;
  margin-right: 16rpx;
}

.expense-delete {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ff4d4f;
  font-size: 32rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #cccccc;
}
