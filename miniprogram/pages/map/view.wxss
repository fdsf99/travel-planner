/* pages/map/view.wxss */
.map-container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.map {
  flex: 1;
  width: 100%;
}

.attractions-list {
  height: 300rpx;
  background-color: white;
  border-top: 2rpx solid #e0e0e0;
}

.attraction-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.attraction-order {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #4CAF50;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.attraction-info {
  flex: 1;
}

.attraction-name {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.attraction-time {
  font-size: 24rpx;
  color: #999;
  display: block;
}
