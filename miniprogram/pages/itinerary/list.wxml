<!--pages/itinerary/list.wxml-->
<view class="container">
  <!-- 行程列表 -->
  <scroll-view 
    class="list-scroll" 
    scroll-y
    bindscrolltolower="onReachBottom"
    refresher-enabled
    refresher-triggered="{{loading}}"
    bindrefresherrefresh="onPullDownRefresh"
  >
    <!-- 行程卡片 -->
    <view 
      class="itinerary-card card"
      wx:for="{{itineraries}}"
      wx:key="id"
      bindtap="navigateToDetail"
      data-id="{{item.id}}"
    >
      <!-- 卡片头部 -->
      <view class="card-header">
        <view class="destination">
          <text class="dest-name">{{item.destination}}</text>
          <text class="dest-tag">{{item.days}}天{{item.budget ? ' ¥' + item.budget.total : ''}}</text>
        </view>
        <view class="card-actions">
          <button 
            class="btn-delete" 
            catchtap="deleteItinerary" 
            data-id="{{item.id}}"
            data-name="{{item.destination}}"
          >
            🗑️
          </button>
        </view>
      </view>

      <!-- 行程信息 -->
      <view class="card-body">
        <view class="info-row">
          <text class="label">📅 出发日期</text>
          <text class="value">{{item.startDate}}</text>
        </view>
        <view class="info-row">
          <text class="label">✨ 主题</text>
          <text class="value">{{item.summary || '智能行程'}}</text>
        </view>
        <view class="info-row" wx:if="{{item.interests}}">
          <text class="label">🎯 兴趣</text>
          <text class="value">{{item.interests.join('、')}}</text>
        </view>
      </view>

      <!-- 卡片底部 -->
      <view class="card-footer">
        <text class="status-tag status-{{item.status}}">
          {{item.status === 'draft' ? '草稿' : item.status === 'confirmed' ? '已确认' : '已完成'}}
        </text>
        <text class="create-time">{{item.created_at}}</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{isEmpty}}">
      <text class="empty-icon">📭</text>
      <text class="empty-text">还没有行程</text>
      <text class="empty-desc">快去生成你的第一个旅行行程吧!</text>
      <button class="btn-create" bindtap="createNewItinerary">
        ✨ 生成行程
      </button>
    </view>

    <!-- 加载状态 -->
    <view class="load-more" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
    
    <view class="load-more" wx:if="{{!hasMore && !isEmpty}}">
      <text>没有更多了</text>
    </view>
  </scroll-view>
</view>
