/* pages/itinerary/detail.wxss */
.summary {
  text-align: center;
}

.dest-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 15rpx;
}

.summary-info {
  font-size: 26rpx;
  color: #999;
  display: flex;
  justify-content: center;
  gap: 15rpx;
}

.date-tabs {
  white-space: nowrap;
  padding: 20rpx 0;
  background-color: white;
  margin-bottom: 20rpx;
}

.date-tab {
  display: inline-block;
  padding: 20rpx 30rpx;
  margin-right: 15rpx;
  border-radius: 8rpx;
  background-color: #f5f5f5;
  text-align: center;
}

.date-tab.active {
  background-color: #4CAF50;
}

.day-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.date-tab.active .day-text {
  color: white;
}

.day-date {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 5rpx;
}

.date-tab.active .day-date {
  color: rgba(255, 255, 255, 0.8);
}

.activities-section {
  margin-bottom: 120rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.theme {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.activity-card {
  margin-bottom: 20rpx;
  position: relative;
  padding-left: 40rpx;
}

.activity-card::before {
  content: '';
  position: absolute;
  left: 15rpx;
  top: 0;
  bottom: 0;
  width: 4rpx;
  background-color: #4CAF50;
  border-radius: 2rpx;
}

.activity-time {
  font-size: 24rpx;
  color: #4CAF50;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.activity-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.activity-desc {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 15rpx;
  line-height: 1.6;
}

.activity-meta {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.activity-tips {
  font-size: 24rpx;
  color: #ff9800;
  background-color: #fff8e1;
  padding: 10rpx 15rpx;
  border-radius: 8rpx;
  margin-top: 10rpx;
}

.action-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background-color: white;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.action-buttons button {
  flex: 1;
  margin: 0;
}

/* 工具箱区域 */
.tools-section {
  margin-top: 24rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.tools-grid {
  display: flex;
  justify-content: space-around;
  gap: 16rpx;
}

.tool-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.tool-item:active {
  background: #e8f5e9;
  transform: scale(0.95);
}

.tool-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.tool-name {
  font-size: 24rpx;
  color: #666666;
}
